 {
    "layer": "top",
    "position": "top",
    "height": 28,
    "exclusive": true,

    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "pulseaudio",
        "backlight",
        "network",
        "custom/vpn",
        "cpu",
        "memory",
        "battery",
        "clock",
        "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/window": {
        "format": "{}",
        "max-length": 50
    },

    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED",
        "on-click": "pactl set-default-sink $(pactl list short sinks | grep -v $(pactl get-default-sink) | cut -f2 | head -n1)",
        "on-click-right": "pavucontrol"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set +1%",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6,
        "interval": 1
    },

        "network": {
        "interface": "wlan0", // Change this to your interface if needed!
        "format-wifi": "  {essid} ({signalStrength}%)",
        "format-ethernet": "󰈀  {ipaddr}/{cidr}",
        "format-disconnected": "⚠  Disconnected",
        "tooltip-format": "  {ifname} via {gwaddr}\n󰇚  {bandwidthDownBits}  󰕒  {bandwidthUpBits}",
        "max-length": 150,
        "min-length": 30,
        "interval": 2
    },

    "custom/vpn": {
    "interval": 3,
    "return-type": "json",
    "format": "{}",
    "exec": "if nmcli connection show --active | grep -iq \"proton\"; then SERVER=$(nmcli -t -f NAME,TYPE connection show --active | grep -i \"proton\" | head -n1 | cut -d: -f1); echo \"{\\\"text\\\": \\\"🔒 Connected\\\", \\\"alt\\\": \\\"connected\\\", \\\"tooltip\\\": \\\"🛡️ Proton VPN Active\\\\nServer: $SERVER\\\"}\"; else echo \"{\\\"text\\\": \\\"🔓 Public\\\", \\\"alt\\\": \\\"disconnected\\\", \\\"tooltip\\\": \\\"⚠️ Not secured by Proton VPN\\\"}\"; fi"
},

    "cpu": {
        "format": "CPU {usage}%"
    },

    "memory": {
        "format": "RAM {percentage}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
    "format": "{icon} {capacity}%",
    "format-charging": "󱐋 {icon} {capacity}%",
    "format-discharging": "{icon} {capacity}%",
    "format-full": "󰂄 {capacity}%",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },

     "clock": {
    "interval": 1,
    "format": "{:%a, %b %d | %I:%M:%S %p}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
}   
 },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}
